# Copy to .env for local dev. Never commit .env.
# All variables are optional; values here match config.toml defaults.

# Server
BIDDER__SERVER__BIND=0.0.0.0:8080

# Telemetry
BIDDER__TELEMETRY__OTLP_ENDPOINT=http://localhost:4318
BIDDER__TELEMETRY__SUCCESS_SAMPLE_RATE=0.01
BIDDER__TELEMETRY__LOG_FORMAT=json

# Metrics
BIDDER__METRICS__BIND=0.0.0.0:9090
