# Copy to .env for local dev. Never commit .env.
# All variables are OPTIONAL — every value here matches config.toml exactly.
# Naming rule: BIDDER__<SECTION>__<FIELD> (double underscore = TOML dot).
# So [latency_budget].frequency_cap_ms → BIDDER__LATENCY_BUDGET__FREQUENCY_CAP_MS.

# ─── Server ─────────────────────────────────────────────────────────────────
BIDDER__SERVER__BIND=0.0.0.0:8080
BIDDER__SERVER__MAX_CONCURRENCY=2000
BIDDER__SERVER__WARMUP_ENABLED=true

# ─── Telemetry / logs ───────────────────────────────────────────────────────
# Empty endpoint = OTLP traces disabled (used by load-test baseline harness).
BIDDER__TELEMETRY__OTLP_ENDPOINT=http://localhost:4318
BIDDER__TELEMETRY__SUCCESS_SAMPLE_RATE=0.01
# log_format: json | pretty
#   json   — one-line structured logs, machine-parseable (Loki/Datadog-friendly) [Recommended for PROD]
#   pretty — human-readable, ANSI-colored when stdout is a TTY (local dev)
BIDDER__TELEMETRY__LOG_FORMAT=json
BIDDER__TELEMETRY__SERVICE_NAME=bidder
# Phase 8: when true, ship 100% of spans and let an OTel Collector decide
# keep/drop via tail sampling (see docker/otel-collector/config.yaml).
# Only enable when a collector with the tail_sampling processor sits in
# front of OTLP_ENDPOINT — otherwise you flood whatever's listening.
BIDDER__TELEMETRY__TAIL_SAMPLING_VIA_COLLECTOR=false

# ─── Metrics (Prometheus exposition) ────────────────────────────────────────
BIDDER__METRICS__BIND=0.0.0.0:9090

# ─── Postgres (catalog source-of-truth) ─────────────────────────────────────
BIDDER__POSTGRES__URL=postgres://bidder:bidder@localhost:5432/bidder
BIDDER__POSTGRES__MAX_CONNECTIONS=8
BIDDER__POSTGRES__MIN_CONNECTIONS=2
BIDDER__POSTGRES__ACQUIRE_TIMEOUT_MS=2000
BIDDER__POSTGRES__IDLE_TIMEOUT_SECS=600
BIDDER__POSTGRES__MAX_LIFETIME_SECS=1800

# ─── Redis ──────────────────────────────────────────────────────────────────
BIDDER__REDIS__URL=redis://localhost:6379
# 0 = use num_cpus at runtime.
BIDDER__REDIS__POOL_SIZE=0
BIDDER__REDIS__SEGMENT_CACHE_CAPACITY=500000
BIDDER__REDIS__SEGMENT_CACHE_TTL_SECS=60

# ─── Catalog (refresh + failure tolerance) ──────────────────────────────────
BIDDER__CATALOG__REFRESH_INTERVAL_SECS=60
BIDDER__CATALOG__MAX_CONSECUTIVE_FAILURES=3

# ─── Pipeline ───────────────────────────────────────────────────────────────
BIDDER__PIPELINE__MAX_CANDIDATES_PER_IMP=20

# ─── Frequency cap ──────────────────────────────────────────────────────────
BIDDER__FREQ_CAP__IMPRESSION_WORKERS=2
# Phase 7: optional in-process capper that wraps the Redis-backed one.
# Single-instance only — see bidder-core/src/frequency/in_process.rs.
BIDDER__FREQ_CAP__IN_PROCESS_ENABLED=false
BIDDER__FREQ_CAP__IN_PROCESS_CAP_CAPACITY=500000
BIDDER__FREQ_CAP__IN_PROCESS_WRITE_BUFFER_SIZE=65536
BIDDER__FREQ_CAP__IN_PROCESS_FLUSH_INTERVAL_MS=1000

# ─── Scoring ────────────────────────────────────────────────────────────────
# kind: feature_weighted | ml | cascade | ab_test
BIDDER__SCORING__KIND=feature_weighted

BIDDER__SCORING__ML__MODEL_PATH=tests/fixtures/test_pctr_model.onnx
BIDDER__SCORING__ML__PARITY_PATH=tests/fixtures/scoring_parity.jsonl
BIDDER__SCORING__ML__INPUT_TENSOR_NAME=features
BIDDER__SCORING__ML__OUTPUT_TENSOR_NAME=pctr
BIDDER__SCORING__ML__POOL_SIZE=2
BIDDER__SCORING__ML__MAX_BATCH=64
BIDDER__SCORING__ML__BATCH_PAD_TO=8

# cascade.stage1 / stage2: feature_weighted | ml | cascade | ab_test
# (use only the leaf kinds — feature_weighted or ml — for stage1/stage2 in
# practice; nesting cascade-in-cascade is allowed by the type but unwise).
BIDDER__SCORING__CASCADE__STAGE1=feature_weighted
BIDDER__SCORING__CASCADE__STAGE2=ml
BIDDER__SCORING__CASCADE__TOP_K=50
BIDDER__SCORING__CASCADE__THRESHOLD=0.0

# ab_test.control / treatment: feature_weighted | ml | cascade | ab_test
BIDDER__SCORING__AB_TEST__CONTROL=feature_weighted
BIDDER__SCORING__AB_TEST__TREATMENT=ml
BIDDER__SCORING__AB_TEST__TREATMENT_SHARE=0.1
BIDDER__SCORING__AB_TEST__HASH_SEED=phase-6-rollout

# ─── Win-notice (HMAC + dedup) ──────────────────────────────────────────────
BIDDER__WIN_NOTICE__REQUIRE_AUTH=true
# HMAC-SHA256 shared secret. Production must NOT leave this empty.
BIDDER__WIN_NOTICE__SECRET=
# Per-SSP HMAC secrets keyed by exchange_id. Empty = use the single SECRET
# above for all exchanges. Inline JSON form when overriding via env:
#   BIDDER__WIN_NOTICE__SECRETS={"google-adx":"<s1>","magnite":"<s2>"}
BIDDER__WIN_NOTICE__SECRETS={}
BIDDER__WIN_NOTICE__DEDUP_TTL_SECS=3600
# Base URL the bidder embeds in each bid's nurl. Empty = no nurl emitted.
BIDDER__WIN_NOTICE__NOTICE_BASE_URL=

# ─── Kafka ──────────────────────────────────────────────────────────────────
# Set BROKERS="" to disable Kafka entirely (NoOpEventPublisher). The baseline
# harness uses that override so connection-retry overhead doesn't pollute
# timings — config.toml itself points at localhost:9092 by default.
BIDDER__KAFKA__BROKERS=localhost:9092
BIDDER__KAFKA__EVENTS_TOPIC=bidder.events.v1
BIDDER__KAFKA__QUEUE_CAPACITY=100000
BIDDER__KAFKA__SEND_TIMEOUT_MS=50
# newest | oldest | random_sample | incident_mode
BIDDER__KAFKA__DROP_POLICY=newest

# ─── Per-stage latency budgets (advisory; counters fire above the limit) ────
# Each stage has its own budget. The bidder enforces a hard ceiling at
# pipeline_deadline_ms / http_timeout_ms; the per-stage values are early-
# warning signals (Prometheus counter bidder.pipeline.stage.budget_exceeded
# tagged by stage) — they do NOT short-circuit the request.
BIDDER__LATENCY_BUDGET__HTTP_PARSE_MS=2
BIDDER__LATENCY_BUDGET__REQUEST_VALIDATE_MS=1
BIDDER__LATENCY_BUDGET__USER_ENRICHMENT_MS=8
BIDDER__LATENCY_BUDGET__CANDIDATE_RETRIEVAL_MS=1
BIDDER__LATENCY_BUDGET__CANDIDATE_LIMIT_MS=1
BIDDER__LATENCY_BUDGET__SCORING_MS=1
BIDDER__LATENCY_BUDGET__FREQUENCY_CAP_MS=10
BIDDER__LATENCY_BUDGET__RANKING_MS=1
BIDDER__LATENCY_BUDGET__BUDGET_PACING_MS=1
BIDDER__LATENCY_BUDGET__RESPONSE_BUILD_MS=1
# Total pipeline deadline — requests over this return 204 immediately.
BIDDER__LATENCY_BUDGET__PIPELINE_DEADLINE_MS=40
# Hard HTTP-layer ceiling (axum timeout middleware).
BIDDER__LATENCY_BUDGET__HTTP_TIMEOUT_MS=50
# Win-notice endpoint timeout — longer; not latency-critical.
BIDDER__LATENCY_BUDGET__WIN_TIMEOUT_MS=500

# ─── Logs ───────────────────────────────────────────────────────────────────
# tracing-subscriber EnvFilter syntax. Bump a specific module to debug without
# making the whole bidder noisy:
#   RUST_LOG=info,bidder_core::pipeline=debug
RUST_LOG=info
