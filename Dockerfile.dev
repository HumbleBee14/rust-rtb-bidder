# syntax=docker/dockerfile:1
# Development image: Debian-based, full toolchain, volume-mount friendly.
# Use for Linux-behavior validation on a macOS host and for linux-tuning feature testing.

FROM rust:1-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# cargo-watch for live-reload dev loop
RUN cargo install cargo-watch --locked

COPY . .

RUN cargo build --release -p bidder-server

EXPOSE 8080 9090

CMD ["cargo", "run", "--release", "-p", "bidder-server"]
