{
  "title": "Bidder — Live",
  "uid": "bidder-live",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bid path RPS (delivered)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bidder_bid_requests_total[1m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 12000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Bid rate (1m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bidder_bid_requests_total{result=\"bid\"}[1m])) / clamp_min(sum(rate(bidder_bid_requests_total[1m])), 1)",
          "legendFormat": "rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bidder_bid_requests_total{result=~\"parse_error|pipeline_error\"}[1m])) / clamp_min(sum(rate(bidder_bid_requests_total[1m])), 1)",
          "legendFormat": "rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pipeline early drops (1m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(bidder_pipeline_early_drop[1m]))",
          "legendFormat": "drops/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Bid outcomes (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (result) (rate(bidder_bid_requests_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Per-stage p99 latency (last bidder summary)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "bidder_pipeline_stage_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Circuit breaker — opens/closes (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (name) (rate(bidder_circuit_breaker_opened[1m]))",
          "legendFormat": "{{name}} opened",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(bidder_circuit_breaker_closed[1m]))",
          "legendFormat": "{{name}} closed",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Hedge — fired vs blocked (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(bidder_redis_hedge_fired[1m])",
          "legendFormat": "fired",
          "refId": "A"
        },
        {
          "expr": "rate(bidder_redis_hedge_blocked[1m])",
          "legendFormat": "blocked",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Freq-cap skips (rate by reason)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(bidder_freq_cap_skipped[1m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Budget-exhausted candidates filtered (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(bidder_budget_exhausted_filtered[1m])",
          "legendFormat": "filtered/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Per-stage budget-exceeded events (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (stage) (rate(bidder_pipeline_stage_budget_exceeded[1m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 50,
      "type": "timeseries",
      "title": "Kafka events_dropped (rate)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(bidder_kafka_events_dropped[1m])",
          "legendFormat": "events/s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Win notices — total / auth_failed / duplicate (rate)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(bidder_win_notices_total[1m])",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "rate(bidder_win_auth_failed_total[1m])",
          "legendFormat": "auth_failed",
          "refId": "B"
        },
        {
          "expr": "rate(bidder_win_duplicate_dropped_total[1m])",
          "legendFormat": "duplicate",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
